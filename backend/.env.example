# Copy this file to .env and fill in all values before running locally.
# NEVER commit .env to version control.

# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.local

# ── Database (leave blank to use SQLite in local dev) ─────────────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/mbpa_portal

# ── Backblaze B2 (leave B2_KEY_ID blank to use local filesystem storage) ──────
# Originally specified as Cloudflare R2 in the design docs (TDD §4.7); the actual
# deployment uses Backblaze B2 instead — same S3-compatible integration shape.
# B2_KEY_ID=your-b2-application-key-id
# B2_APPLICATION_KEY=your-b2-application-key
# B2_BUCKET_NAME=mbpa-portal
# B2_REGION=us-west-004

# ── Email (Resend SMTP) ───────────────────────────────────────────────────────
# Free tier is capped at 100 emails/day (not just 3,000/month) — a real go-live
# blocker for bursty OTP traffic; see Docs/runbooks/resend_dns.md (AC-23).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=Mumbai Port Authority <noreply@mbpa.example.gov>

# ── Aadhaar HMAC pepper ───────────────────────────────────────────────────────
# High-entropy secret; NEVER store in DB or logs. Rotate by re-hashing all records.
# Required in production — identity.E001 fails `manage.py check` if unset.
# AADHAAR_PEPPER=replace-with-64-char-random-hex

# ── DSC (Digital Signature Certificate) trust root ────────────────────────────
# Must point to a real CCA India root certificate (DER-encoded X.509) before
# go-live — the checked-in cca_trust_root.der is a placeholder. Required in
# production — certificates.E001 fails `manage.py check` if it isn't a real cert.
# DSC_TRUST_ROOT_PATH=/path/to/cca_trust_root.der

# ── Production only ───────────────────────────────────────────────────────────
# DJANGO_ALLOWED_HOSTS=mbpa.example.gov
# CSRF_TRUSTED_ORIGINS=https://mbpa.example.gov
# SECURE_HSTS_SECONDS defaults to 300 (a short ramp-up value) — raise to
# 31536000 once HTTPS is confirmed stable, before relying on HSTS for real.
# SECURE_HSTS_SECONDS=300
